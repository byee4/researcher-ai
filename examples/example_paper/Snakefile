# Snakefile — eCLIP-seq pipeline
# Generated by researcher-ai from PMID 26971820 (Van Nostrand et al. 2016)
# DOI: 10.1038/nmeth.3810 | GEO: GSE77695
#
# Usage:
#   snakemake --snakefile Snakefile --cores 16 --use-conda
#
# Configure: edit config.yaml to point to your FASTQ files and genome index.

configfile: "config.yaml"

SAMPLES = config.get("samples", [])
GENOME  = config.get("genome_dir", "genomes/hg19")
GTF     = config.get("gtf", "genomes/hg19.gtf")

rule all:
    input:
        expand("normalized/{sample}_normalized_peaks.bed", sample=SAMPLES),
        expand("qc/{sample}_fastqc.html", sample=SAMPLES),
        "multiqc/multiqc_report.html",


# ── Step 1: Adapter trimming (Cutadapt v1.9) ──────────────────────────────────
rule cutadapt_trim:
    input:
        r1 = "raw/{sample}_R1.fastq.gz",
        r2 = "raw/{sample}_R2.fastq.gz",
    output:
        r1 = "trimmed/{sample}_R1_trimmed.fastq.gz",
        r2 = "trimmed/{sample}_R2_trimmed.fastq.gz",
    log:
        "logs/cutadapt/{sample}.log",
    threads: 4
    resources:
        mem_mb = 8192,
    conda:
        "envs/cutadapt.yaml"
    shell:
        """
        cutadapt \
            -a AGATCGGAAGAGC \
            -A AGATCGGAAGAGC \
            -q 6 \
            --minimum-length 18 \
            -j {threads} \
            -o {output.r1} \
            -p {output.r2} \
            {input.r1} {input.r2} \
            > {log} 2>&1
        """


# ── Step 2: FastQC on trimmed reads ───────────────────────────────────────────
rule fastqc:
    input:
        "trimmed/{sample}_R1_trimmed.fastq.gz",
    output:
        html = "qc/{sample}_fastqc.html",
        zip  = "qc/{sample}_fastqc.zip",
    log:
        "logs/fastqc/{sample}.log",
    threads: 2
    resources:
        mem_mb = 4096,
    conda:
        "envs/qc.yaml"
    shell:
        "fastqc {input} -o qc/ > {log} 2>&1"


# ── Step 3: STAR alignment (v2.4.0j) ─────────────────────────────────────────
rule star_align:
    input:
        r1 = "trimmed/{sample}_R1_trimmed.fastq.gz",
        r2 = "trimmed/{sample}_R2_trimmed.fastq.gz",
    output:
        bam = "aligned/{sample}.Aligned.sortedByCoord.out.bam",
        bai = "aligned/{sample}.Aligned.sortedByCoord.out.bam.bai",
    params:
        genome    = GENOME,
        prefix    = "aligned/{sample}.",
        max_multi = 1,
    log:
        "logs/star/{sample}.log",
    threads: 8
    resources:
        mem_mb = 32768,
    conda:
        "envs/star.yaml"
    shell:
        """
        STAR \
            --runThreadN {threads} \
            --genomeDir {params.genome} \
            --readFilesIn {input.r1} {input.r2} \
            --readFilesCommand zcat \
            --outSAMtype BAM SortedByCoordinate \
            --outSAMattributes NH HI NM MD \
            --outFilterMultimapNmax {params.max_multi} \
            --outFileNamePrefix {params.prefix} \
            > {log} 2>&1
        samtools index {output.bam}
        """


# ── Step 4: UMI-aware deduplication ──────────────────────────────────────────
rule umi_dedup:
    input:
        bam = "aligned/{sample}.Aligned.sortedByCoord.out.bam",
        bai = "aligned/{sample}.Aligned.sortedByCoord.out.bam.bai",
    output:
        bam = "dedup/{sample}.dedup.bam",
        bai = "dedup/{sample}.dedup.bam.bai",
    log:
        "logs/dedup/{sample}.log",
    threads: 4
    resources:
        mem_mb = 16384,
    conda:
        "envs/umi_tools.yaml"
    shell:
        """
        umi_tools dedup \
            --stdin {input.bam} \
            --stdout {output.bam} \
            --paired \
            --log {log}
        samtools index {output.bam}
        """


# ── Step 5: Peak calling with CLIPper ─────────────────────────────────────────
rule clipper_peaks:
    input:
        bam = "dedup/{sample}.dedup.bam",
    output:
        peaks = "peaks/{sample}_peaks.bed",
    params:
        species = "hg19",
    log:
        "logs/clipper/{sample}.log",
    threads: 8
    resources:
        mem_mb = 16384,
    conda:
        "envs/clipper.yaml"
    shell:
        """
        clipper \
            --bam {input.bam} \
            --species {params.species} \
            --outfile {output.peaks} \
            > {log} 2>&1
        """


# ── Step 6: Normalize against size-matched input ─────────────────────────────
rule normalize_peaks:
    input:
        eclip_bam   = "dedup/{sample}.dedup.bam",
        input_bam   = "dedup/{sample}_input.dedup.bam",
        eclip_peaks = "peaks/{sample}_peaks.bed",
    output:
        normalized = "normalized/{sample}_normalized_peaks.bed",
    log:
        "logs/normalize/{sample}.log",
    threads: 4
    resources:
        mem_mb = 8192,
    conda:
        "envs/clipper.yaml"
    shell:
        """
        # Normalization using CLIPper's input-normalization script
        # Computes enrichment of eCLIP peaks over size-matched input
        python -m clipper.compute_read_enrichment \
            --ip {input.eclip_bam} \
            --input {input.input_bam} \
            --peaks {input.eclip_peaks} \
            --out {output.normalized} \
            > {log} 2>&1
        """


# ── Step 7: MultiQC ───────────────────────────────────────────────────────────
rule multiqc:
    input:
        expand("qc/{sample}_fastqc.zip", sample=SAMPLES),
        expand("logs/star/{sample}.log", sample=SAMPLES),
    output:
        "multiqc/multiqc_report.html",
    log:
        "logs/multiqc.log",
    conda:
        "envs/qc.yaml"
    shell:
        "multiqc qc/ logs/ -o multiqc/ > {log} 2>&1"
